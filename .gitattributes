# Normalise line endings — text files use LF in repo, checkout as-is on each OS
* text=auto eol=lf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.mp4 binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
